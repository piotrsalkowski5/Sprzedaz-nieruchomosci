{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "outDir": "dist",
    "rootDir": "src",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "noEmit": false,
    "noEmitOnError": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": ["src"]
}